PORT=3000
NODE_ENV=production
VIDEO_ROOT=/srv/videos
APP_USERNAME=admin
APP_PASSWORD=admin
# Para producao, prefira APP_PASSWORD_HASH e remova APP_PASSWORD.
# Gere com: npm run hash-password -- "sua-senha-forte"
# APP_PASSWORD_HASH=scrypt:...
SESSION_SECRET=troque-por-uma-string-aleatoria-grande
# Use true apenas quando estiver atras de HTTPS/reverse proxy na VPS.
TRUST_PROXY=false
